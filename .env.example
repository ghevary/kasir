# Database
DB_USER=pos_user
DB_PASSWORD=supersecretpassword
DB_NAME=pos_db
DATABASE_URL=postgresql://pos_user:supersecretpassword@localhost:5432/pos_db

# Backend
PORT=4000
JWT_SECRET=your_jwt_secret_here
BETTER_AUTH_SECRET=your_better_auth_secret
